---
import FilterBar from "../components/composite/FilterBar.astro";
import RecommendationsPanel from "../components/composite/RecommendationsPanel.astro";
import ReportPageLayout from "../components/layout/ReportPageLayout.astro";
import DependencyHealthRow from "../components/domain/DependencyHealthRow.astro";
import StatTile from "../components/domain/StatTile.astro";

const rows = [
	{ name: "react-query", version: "v5.12.0", status: "stable", latest: "5.12.0", score: 98, activity: "2 days ago" },
	{ name: "lodash-es", version: "v4.17.21", status: "outdated", latest: "4.18.0", score: 42, activity: "8 months ago" },
	{ name: "old-legacy-ui", version: "v1.0.4", status: "abandoned", latest: "N/A", score: 12, activity: "3 years ago" },
	{ name: "tailwindcss", version: "v3.4.1", status: "stable", latest: "3.4.1", score: 100, activity: "Today" },
];
---

<ReportPageLayout
	pageTitle="Dependency Health Report"
	headerTitle="Dependency Health"
	headerSubtitle="Package maintenance and freshness across active dependencies."
	sidebarActive="health"
	topActive="inventory"
	topSearchPlaceholder="Scan projects..."
>
	<section class="mb-4 grid grid-cols-1 gap-3 xl:grid-cols-3">
		<StatTile label="Outdated Packages" value="14" hint="12%" progress={35} tone="critical" />
		<StatTile label="Abandoned Projects" value="3" hint="Critical risk" progress={15} tone="high" />
		<StatTile label="Avg. Update Delay" value="42" hint="Days behind" progress={65} tone="medium" />
	</section>

	<FilterBar
		tabItems={[
			{ key: "all", label: "All" },
			{ key: "prod", label: "Production" },
			{ key: "dev", label: "Dev" },
		]}
		activeTab="all"
		searchPlaceholder="Search packages..."
	/>

	<section class="mt-4 grid grid-cols-1 gap-4 xl:grid-cols-[2fr_1fr]">
		<div class="grid gap-3">
			{
				rows.map((row) => (
					<DependencyHealthRow
						name={row.name}
						version={row.version}
						status={row.status as "stable" | "outdated" | "abandoned"}
						latest={row.latest}
						score={row.score}
						activity={row.activity}
					/>
				))
			}
		</div>
		<RecommendationsPanel
			title="Priority Resolution"
			summary="System architecture recommends immediate replacement of legacy UI components detected in sub-modules."
			items={[
				{
					icon: "swap_horizontal_circle",
					title: "Replace old-legacy-ui",
					body: "Transition to @modern/core-ui for long-term maintenance and security posture.",
				},
				{
					icon: "update",
					title: "Upgrade lodash-es",
					body: "Upgrade to v4.18.0 to resolve known non-critical vulnerabilities.",
				},
				{
					icon: "shield_with_heart",
					title: "Lock Dependencies",
					body: "Enable strict lockfile integrity checks in CI to prevent supply-chain poisoning.",
				},
			]}
		/>
	</section>
</ReportPageLayout>
