---
import UploadPanel from "../components/composite/UploadPanel.astro";
import AppShell from "../components/layout/AppShell.astro";
import FooterBar from "../components/layout/FooterBar.astro";
import TopNav from "../components/layout/TopNav.astro";
import Card from "../components/ui/Card.astro";
import Layout from "../layouts/Layout.astro";

const navLinks = [
	{ key: "dashboard", label: "Dashboard", href: "#" },
	{ key: "reports", label: "Reports", href: "#" },
];
---

<Layout title="Initial Dependency | AI Reachability Analysis">
	<AppShell withTopbar={true} withFooter={true}>
		<Fragment slot="topbar">
			<TopNav links={navLinks} active="dashboard" searchPlaceholder="Scan projects..." />
		</Fragment>

		<section class="hero">
			<h1>Initial Dependency</h1>
			<p>AI-powered reachability analysis for your dependencies.</p>
		</section>

		<div class="center">
			<UploadPanel />
		</div>

		<section class="features">
			<Card>
				<h3>Deep Context</h3>
				<p>
					Beyond simple vulnerability matching, we analyze actual execution paths to determine if a vulnerable
					dependency is truly reachable.
				</p>
			</Card>
			<Card>
				<h3>Smart Prioritization</h3>
				<p>
					Reduce security fatigue by filtering out noise and focus on initial dependencies creating real attack
					surfaces.
				</p>
			</Card>
		</section>

		<Fragment slot="footer">
			<FooterBar links={[{ label: "GitHub" }, { label: "Documentation" }, { label: "Privacy Policy" }]} />
		</Fragment>
	</AppShell>
</Layout>

<style>
	.hero {
		text-align: center;
		padding: 2.2rem 1rem 1.6rem;
	}

	.hero h1 {
		margin: 0;
		font-size: clamp(2rem, 6vw, 3.4rem);
		letter-spacing: -0.03em;
	}

	.hero p {
		margin: 0.7rem auto 0;
		max-width: 36rem;
		font-size: 1rem;
		color: var(--color-text-secondary);
	}

	.center {
		max-width: 52rem;
		margin: 0 auto;
	}

	.features {
		max-width: 64rem;
		margin: 2.2rem auto 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.9rem;
	}

	.features h3 {
		margin: 0 0 0.4rem;
		font-size: 0.92rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-primary);
	}

	.features p {
		margin: 0;
		color: var(--color-text-secondary);
		font-size: 0.86rem;
		line-height: 1.5;
	}

	@media (max-width: 800px) {
		.features {
			grid-template-columns: 1fr;
		}
	}
</style>
