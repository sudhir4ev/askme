---
import FilterBar from '../components/composite/FilterBar.astro'
import AppShell from '../components/layout/AppShell.astro'
import FooterBar from '../components/layout/FooterBar.astro'
import PageHeader from '../components/layout/PageHeader.astro'
import SidebarNav from '../components/layout/SidebarNav.astro'
import TopNav from '../components/layout/TopNav.astro'
import StatTile from '../components/domain/StatTile.astro'
import VulnerabilityItem from '../components/domain/VulnerabilityItem.astro'
import Button from '../components/ui/Button.astro'
import Layout from '../layouts/Layout.astro'

const sideItems = [
   { key: 'critical', label: 'Critical Reachability', icon: 'radar', href: '/critical-reachability-report' },
   { key: 'license', label: 'License Compliance', icon: 'gavel', href: '/license-compliance-report' },
   { key: 'health', label: 'Dependency Health', icon: 'health_and_safety', href: '/dependency-health-report' },
]
---

<Layout title="Critical Reachability Report">
   <AppShell withSidebar={true} withTopbar={true} withFooter={true}>
      <Fragment slot="sidebar">
         <SidebarNav brand="Initial Dependency" subtitle="Precision Architect" items={sideItems} active="critical" />
      </Fragment>
      <Fragment slot="topbar">
         <TopNav
            links={[
               { key: 'dashboard', label: 'Dashboard' },
               { key: 'inventory', label: 'Inventory' },
               { key: 'reports', label: 'Reports' },
            ]}
            active="inventory"
            searchPlaceholder="Search libraries..."
         />
      </Fragment>

      <PageHeader title="Dependency-Core-V1" subtitle="Scanned 4 minutes ago • Source: main branch">
         <Button slot="actions" variant="secondary">
            <span class="material-symbols-outlined">download</span>
            Download Report
         </Button>
      </PageHeader>

      <section class="metrics">
         <StatTile label="Total Dependencies" value="142" hint="+12 from last scan" tone="success" />
         <StatTile label="Vulnerabilities Detected" value="12" hint="3 critical, 9 high" />
         <StatTile label="Reachable Risks" value="4" hint="Immediate action" tone="critical" />
         <StatTile label="Security Posture" value="Critical" hint="Reachable vulnerabilities found" tone="critical" />
      </section>

      <FilterBar
         tabItems={[
            { key: 'reachable', label: 'Reachable' },
            { key: 'all', label: 'All' },
         ]}
         activeTab="reachable"
         searchPlaceholder="Search libraries..."
         showSeverity={true}
      />

      <section class="list">
         <VulnerabilityItem
            library="lodash"
            version="v4.17.20"
            severity="critical"
            reachability="reachable"
            cve="CVE-2020-8203"
            description="Prototype pollution vulnerability in lodash before 4.17.21 may allow denial-of-service or arbitrary code execution via crafted payloads."
            remediation="Upgrade lodash to version 4.17.21 or higher."
            expanded={true}
         />
         <VulnerabilityItem
            library="axios"
            version="v0.21.1"
            severity="high"
            reachability="reachable"
            cve="CVE-2021-3749"
         />
         <VulnerabilityItem
            library="moment"
            version="v2.29.1"
            severity="medium"
            reachability="not-reachable"
            cve="CVE-2022-24785"
         />
      </section>

      <div class="actions">
         <Button variant="secondary">Load More Results</Button>
      </div>

      <Button variant="fab" class="fab" aria-label="Download report">
         <span class="material-symbols-outlined">ios_share</span>
      </Button>

      <Fragment slot="footer">
         <FooterBar links={[{ label: 'GitHub' }, { label: 'Documentation' }, { label: 'Privacy Policy' }]} />
      </Fragment>
   </AppShell>
</Layout>

<style>
   .metrics {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.7rem;
      margin-bottom: 1rem;
   }

   .list {
      display: grid;
      gap: 0.7rem;
      margin-top: 1rem;
   }

   .actions {
      display: grid;
      place-items: center;
      margin-top: 1rem;
   }

   .fab {
      position: fixed;
      right: 1.5rem;
      bottom: 1.5rem;
   }

   @media (max-width: 1100px) {
      .metrics {
         grid-template-columns: 1fr;
      }
   }
</style>
