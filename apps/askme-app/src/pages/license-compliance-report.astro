---
import FilterBar from "../components/composite/FilterBar.astro";
import PaginationBar from "../components/composite/PaginationBar.astro";
import AppShell from "../components/layout/AppShell.astro";
import FooterBar from "../components/layout/FooterBar.astro";
import PageHeader from "../components/layout/PageHeader.astro";
import SidebarNav from "../components/layout/SidebarNav.astro";
import TopNav from "../components/layout/TopNav.astro";
import LicenseEntryItem from "../components/domain/LicenseEntryItem.astro";
import StatTile from "../components/domain/StatTile.astro";
import Button from "../components/ui/Button.astro";
import Layout from "../layouts/Layout.astro";

const sideItems = [
	{ key: "critical", label: "Critical Reachability", icon: "radar", href: "/critical-reachability-report" },
	{ key: "license", label: "License Compliance", icon: "gavel", href: "/license-compliance-report" },
	{ key: "health", label: "Dependency Health", icon: "health_and_safety", href: "/dependency-health-report" },
];

const entries = [
	{ pkg: "core-binary-transpiler", version: "v4.2.1-stable", license: "AGPL-3.0-only", risk: "critical", hash: "0x7F2A...E4B" },
	{ pkg: "ui-system-primitive", version: "v2.0.0-rc3", license: "GPL-2.0-or-later", risk: "high", hash: "0x21B0...D9C" },
	{ pkg: "fast-deep-copy", version: "v1.2.9", license: "MIT", risk: "compliant", hash: "0x88C1...A22" },
	{
		pkg: "react-native-svg-transformer",
		version: "v0.14.3",
		license: "Apache-2.0",
		risk: "compliant",
		hash: "0xAF04...77E",
	},
	{
		pkg: "internal-legacy-adapter",
		version: "v9.1.0-alpha",
		license: "Unknown / Unspecified",
		risk: "unknown",
		hash: "0x0000...000",
	},
];
---

<Layout title="License Compliance Report">
	<AppShell withSidebar={true} withTopbar={true} withFooter={true}>
		<Fragment slot="sidebar">
			<SidebarNav brand="Initial Dependency" subtitle="Precision Architect" items={sideItems} active="license" />
		</Fragment>
		<Fragment slot="topbar">
			<TopNav
				links={[
					{ key: "dashboard", label: "Dashboard" },
					{ key: "reports", label: "Reports" },
					{ key: "inventory", label: "Inventory" },
				]}
				active="reports"
				searchPlaceholder="Search licenses..."
			/>
		</Fragment>

		<PageHeader
			title="License Compliance"
			subtitle="Full legal audit of active dependencies across the production cluster."
		>
			<Button slot="actions" variant="secondary">
				<span class="material-symbols-outlined">file_download</span>
				Export Compliance Report
			</Button>
		</PageHeader>

		<section class="metrics">
			<StatTile label="Total Licenses" value="142" hint="+12 this month" />
			<StatTile label="Compliance Risks" value="03 / 08" hint="Critical / High" tone="critical" />
			<StatTile label="Unknown Licenses" value="02" hint="Review required" tone="medium" />
		</section>

		<FilterBar
			tabItems={[
				{ key: "all", label: "All Licenses" },
				{ key: "risky", label: "Risky Only" },
				{ key: "unclassified", label: "Unclassified" },
			]}
			activeTab="all"
			searchPlaceholder="Search licenses..."
		/>

		<section class="list">
			{
				entries.map((entry) => (
					<LicenseEntryItem
						pkg={entry.pkg}
						version={entry.version}
						license={entry.license}
						risk={entry.risk as "critical" | "high" | "compliant" | "unknown"}
						hash={entry.hash}
					/>
				))
			}
		</section>

		<PaginationBar label="Showing 5 of 142 unique dependency licenses detected" />

		<Fragment slot="footer">
			<FooterBar links={[{ label: "GitHub" }, { label: "Documentation" }, { label: "Privacy Policy" }]} />
		</Fragment>
	</AppShell>
</Layout>

<style>
	.metrics {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.7rem;
		margin-bottom: 1rem;
	}

	.list {
		display: grid;
		gap: 0.7rem;
		margin: 1rem 0;
	}

	@media (max-width: 1000px) {
		.metrics {
			grid-template-columns: 1fr;
		}
	}
</style>
