---
interface Props {
	title: string;
	subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="mb-5 flex flex-wrap items-end justify-between gap-4">
	<div>
		<h1 class="m-0 text-[clamp(1.5rem,2vw,2rem)] leading-[1.1]">{title}</h1>
		{subtitle && <p class="mt-2 mb-0 max-w-[44rem] text-[0.92rem] text-[var(--color-text-secondary)]">{subtitle}</p>}
	</div>
	<div class="flex gap-2"><slot name="actions" /></div>
</header>
