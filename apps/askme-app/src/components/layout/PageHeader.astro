---
interface Props {
	title: string;
	subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="page-header">
	<h1>{title}</h1>
	{subtitle && <p>{subtitle}</p>}
	<div class="actions"><slot name="actions" /></div>
</header>

<style>
	.page-header {
		display: flex;
		justify-content: space-between;
		align-items: end;
		gap: 1rem;
		margin-bottom: 1.2rem;
		flex-wrap: wrap;
	}

	h1 {
		margin: 0;
		font-size: clamp(1.5rem, 2vw, 2rem);
		line-height: 1.1;
	}

	p {
		margin: 0.45rem 0 0;
		color: var(--color-text-secondary);
		font-size: 0.92rem;
		max-width: 44rem;
	}

	.actions {
		display: flex;
		gap: 0.5rem;
	}
</style>
