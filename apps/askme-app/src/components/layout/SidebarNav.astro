---
import Button from "../ui/Button.astro";
import Avatar from "../ui/Avatar.astro";

interface NavItem {
	key: string;
	label: string;
	icon: string;
	href?: string;
}

interface Props {
	brand: string;
	subtitle?: string;
	items: NavItem[];
	active: string;
}

const { brand, subtitle, items, active } = Astro.props;
---

<div class="flex h-full flex-col border-r border-[var(--color-border)] bg-[#f8fafc] p-4">
	<div>
		<h1 class="m-0 text-[1.05rem]">{brand}</h1>
		{
			subtitle && <p class="mt-[0.3rem] mb-0 text-[0.67rem] uppercase tracking-[0.1em] text-[var(--color-muted)]">{subtitle}</p>
		}
	</div>

	<nav class="mt-[1.3rem] flex flex-col gap-[0.3rem]">
		{
			items.map((item) => (
				<a
					class:list={[
						"flex items-center gap-[0.6rem] rounded-[var(--radius-md)] px-[0.7rem] py-[0.65rem] text-[0.88rem] text-[var(--color-text-secondary)]",
						item.key === active && "border border-[var(--color-border)] bg-white text-[#1d4ed8]",
					]}
					href={item.href ?? "#"}
				>
					<span class="material-symbols-outlined">{item.icon}</span>
					<span>{item.label}</span>
				</a>
			))
		}
	</nav>

	<div class="mt-auto border-t border-[var(--color-border)] pt-4">
		<Button variant="gradient" fullWidth={true}>Run New Analysis</Button>
		<div class="mt-4 flex items-center gap-[0.55rem]">
			<Avatar initials="JD" />
			<div>
				<strong class="block text-xs">Arch. J. Doe</strong>
				<small class="text-[0.62rem] uppercase tracking-[0.04em] text-[var(--color-muted)]">Admin Access</small>
			</div>
		</div>
	</div>
</div>
