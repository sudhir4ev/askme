---
import Avatar from "../ui/Avatar.astro";
import Input from "../ui/Input.astro";

interface LinkItem {
	key: string;
	label: string;
	href?: string;
}

interface Props {
	links: LinkItem[];
	active: string;
	searchPlaceholder?: string;
}

const { links, active, searchPlaceholder = "Search..." } = Astro.props;
---

<div class="flex items-center justify-between gap-4 border-b border-[var(--color-border)] bg-white/90 px-[1.1rem] py-[0.65rem] backdrop-blur-[8px]">
	<nav class="flex gap-[1.1rem]">
		{
			links.map((link) => (
				<a
					class:list={[
						"border-b-2 border-transparent pb-[0.3rem] text-[0.84rem] font-semibold text-[var(--color-text-secondary)]",
						link.key === active && "border-[var(--color-primary)] text-[var(--color-primary)]",
					]}
					href={link.href ?? "#"}
				>
					{link.label}
				</a>
			))
		}
	</nav>

	<div class="flex items-center gap-2">
		<div class="w-[min(18rem,45vw)]">
			<Input icon="search" placeholder={searchPlaceholder} />
		</div>
		<button
			class="grid h-8 w-8 place-items-center rounded-full border border-[var(--color-border)] bg-white text-[var(--color-text-secondary)]"
			type="button"
			aria-label="Notifications"
		>
			<span class="material-symbols-outlined">notifications</span>
		</button>
		<Avatar initials="JD" />
	</div>
</div>
