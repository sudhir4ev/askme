---
interface FooterLink {
	label: string;
	href?: string;
}

interface Props {
	links: FooterLink[];
}

const { links } = Astro.props;
---

<div class="flex flex-wrap items-center justify-between gap-3.5 border-t border-[var(--color-border)] bg-white px-[1.4rem] py-4">
	<span class="font-mono text-[0.7rem] uppercase tracking-[0.08em] text-[var(--color-muted)]">
		© 2024 Initial Dependency
	</span>
	<nav class="flex gap-4">
		{
			links.map((link) => (
				<a class="text-[0.74rem] uppercase tracking-[0.05em] text-[var(--color-muted)]" href={link.href ?? "#"}>{link.label}</a>
			))
		}
	</nav>
</div>
