---
interface FooterLink {
	label: string;
	href?: string;
}

interface Props {
	links: FooterLink[];
}

const { links } = Astro.props;
---

<div class="footer-wrap">
	<span class="mono">© 2024 Initial Dependency</span>
	<nav>
		{
			links.map((link) => (
				<a href={link.href ?? "#"}>{link.label}</a>
			))
		}
	</nav>
</div>

<style>
	.footer-wrap {
		border-top: 1px solid var(--color-border);
		padding: 1rem 1.4rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: #fff;
		gap: 0.8rem;
		flex-wrap: wrap;
	}

	span {
		font-size: 0.7rem;
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	nav {
		display: flex;
		gap: 1rem;
	}

	a {
		font-size: 0.74rem;
		color: var(--color-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
</style>
