---
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import Card from "../ui/Card.astro";

interface Props {
	pkg: string;
	version: string;
	license: string;
	risk: "critical" | "high" | "compliant" | "unknown";
	hash: string;
}

const { pkg, version, license, risk, hash } = Astro.props;

const tone =
	risk === "critical" ? "critical" : risk === "high" ? "high" : risk === "compliant" ? "success" : "muted";
---

<Card variant="interactive" padding="md">
	<div class="grid grid-cols-1 items-center gap-4 md:grid-cols-[2fr_auto_auto]">
		<div>
			<strong class="block text-base">{pkg}</strong>
			<small class="block font-mono text-[0.72rem] text-[var(--color-text-secondary)]">
				{version}
			</small>
			<p class="mt-1 mb-0 font-mono text-[0.8rem] text-[var(--color-text-secondary)]">
				{license}
			</p>
		</div>
		<div class="text-left md:text-right">
			<Badge tone={tone}>{risk}</Badge>
			<small class="block font-mono text-[0.72rem] text-[var(--color-text-secondary)]">
				{hash}
			</small>
		</div>
		<div class="flex items-center gap-1.5">
			<Button variant="icon"><span class="material-symbols-outlined">visibility</span></Button>
			<Button variant="secondary" size="sm">{risk === "unknown" ? "Analyze" : "Details"}</Button>
		</div>
	</div>
</Card>
