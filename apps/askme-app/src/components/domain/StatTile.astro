---
import Card from "../ui/Card.astro";
import SectionLabel from "../ui/SectionLabel.astro";
import ProgressBar from "../ui/ProgressBar.astro";

interface Props {
	label: string;
	value: string | number;
	hint?: string;
	progress?: number;
	tone?: "primary" | "critical" | "high" | "medium" | "success";
}

const { label, value, hint, progress, tone = "primary" } = Astro.props;
---

<Card variant="interactive" padding="md">
	<SectionLabel>{label}</SectionLabel>
	<div class="mt-2 mb-3 flex items-baseline gap-2">
		<strong class="text-[2rem] leading-none">{value}</strong>
		{hint && <span class="text-xs text-[var(--color-text-secondary)]">{hint}</span>}
	</div>
	{typeof progress === "number" && <ProgressBar value={progress} tone={tone} />}
</Card>
