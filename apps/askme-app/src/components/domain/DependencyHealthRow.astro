---
import Badge from "../ui/Badge.astro";
import Card from "../ui/Card.astro";
import ProgressBar from "../ui/ProgressBar.astro";

interface Props {
	name: string;
	version: string;
	status: "stable" | "outdated" | "abandoned";
	latest: string;
	score: number;
	activity: string;
}

const { name, version, status, latest, score, activity } = Astro.props;
const statusTone = status === "stable" ? "success" : status === "outdated" ? "high" : "muted";
const scoreTone = score > 85 ? "success" : score > 50 ? "medium" : "critical";
---

<Card variant="interactive" padding="md">
	<div class="grid grid-cols-1 items-center gap-4 md:grid-cols-[2fr_1.5fr_1.5fr_1fr]">
		<div>
			<strong class="block">{name}</strong>
			<small class="font-mono text-[0.72rem] text-[var(--color-text-secondary)]">
				{version}
			</small>
		</div>
		<div class="text-left md:text-center">
			<Badge tone={statusTone}>{status}</Badge>
			<small class="block text-[0.72rem] text-[var(--color-text-secondary)]">Latest: {latest}</small>
		</div>
		<div>
			<small class="font-mono text-[0.72rem] text-[var(--color-text-secondary)]">
				{score}/100
			</small>
			<ProgressBar value={score} tone={scoreTone} />
		</div>
		<div>
			<strong class="block">{activity}</strong>
			<small class="text-[0.72rem] text-[var(--color-text-secondary)]">Last Commit</small>
		</div>
	</div>
</Card>
