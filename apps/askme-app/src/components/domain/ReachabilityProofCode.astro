---
interface Props {
	file: string;
	line: number;
	lines: string[];
}

const { file, line, lines } = Astro.props;
---

<div class="overflow-hidden rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-code-bg)]">
	<div class="flex items-center justify-between border-b border-[var(--color-border)] px-3 py-2 text-[0.68rem] text-[var(--color-text-secondary)] font-mono">
		<span>{file}</span>
		<span>Line {line}</span>
	</div>
	<pre class="m-0 overflow-x-auto p-3 text-[0.77rem] font-mono"><code>{lines.join("\n")}</code></pre>
</div>
