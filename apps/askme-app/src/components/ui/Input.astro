---
interface Props {
	type?: string;
	placeholder?: string;
	name?: string;
	value?: string;
	icon?: string;
}

const { type = "text", placeholder, name, value, icon } = Astro.props;
---

<label class:list={["input-wrap", icon && "input-wrap--icon"]}>
	{icon && <span class="material-symbols-outlined">{icon}</span>}
	<input {type} {placeholder} {name} {value} />
</label>

<style>
	.input-wrap {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		width: 100%;
		background: var(--color-bg-primary);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		padding: 0.55rem 0.7rem;
	}

	.input-wrap--icon .material-symbols-outlined {
		color: var(--color-muted);
		font-size: 1rem;
	}

	input {
		width: 100%;
		border: 0;
		outline: 0;
		background: transparent;
		font-size: 0.875rem;
		color: var(--color-text-primary);
	}

	input::placeholder {
		color: #9ca3af;
	}
</style>
