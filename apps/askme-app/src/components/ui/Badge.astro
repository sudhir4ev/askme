---
interface Props {
	tone?:
		| "default"
		| "critical"
		| "high"
		| "medium"
		| "success"
		| "muted"
		| "info";
	size?: "sm" | "md";
}

const { tone = "default", size = "sm" } = Astro.props;
const sizeClasses = {
	sm: "px-2 py-0.5 text-[0.625rem]",
	md: "px-2.5 py-1 text-xs",
} as const;
const toneClasses = {
	default: "bg-[#dbeafe] text-[#1e3a8a]",
	critical: "bg-[#fee2e2] text-[#991b1b]",
	high: "bg-[#ffedd5] text-[#9a3412]",
	medium: "bg-[#fef9c3] text-[#854d0e]",
	success: "bg-[#dcfce7] text-[#166534]",
	muted: "bg-[#e5e7eb] text-[#374151]",
	info: "bg-[#e0e7ff] text-[#3730a3]",
} as const;
---

<span
	class:list={[
		"inline-flex items-center gap-1 rounded-full font-bold uppercase tracking-[0.06em]",
		sizeClasses[size],
		toneClasses[tone],
	]}
><slot /></span>
