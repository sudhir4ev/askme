---
interface Props {
	variant?: "primary" | "secondary" | "ghost" | "danger" | "gradient" | "icon" | "fab";
	size?: "sm" | "md" | "lg";
	href?: string;
	fullWidth?: boolean;
	type?: "button" | "submit" | "reset";
	class?: string;
}

const {
	variant = "primary",
	size = "md",
	href,
	fullWidth = false,
	type = "button",
	class: customClass = "",
	...rest
} = Astro.props;

const Tag = href ? "a" : "button";
const sizeClasses = {
	sm: "px-2.5 py-1.5 text-xs",
	md: "px-3.5 py-2.5 text-sm",
	lg: "px-4 py-3 text-[0.95rem]",
} as const;
const variantClasses = {
	primary: "bg-[var(--color-primary)] text-white",
	secondary: "border-[var(--color-border)] bg-[var(--color-bg-primary)] text-[var(--color-text-primary)]",
	ghost: "bg-transparent text-[var(--color-text-secondary)]",
	danger: "bg-[var(--color-critical)] text-white",
	gradient: "bg-gradient-to-br from-[#2563eb] to-[#3b82f6] text-white",
	icon: "h-8 w-8 border-[var(--color-border)] bg-[var(--color-bg-primary)] p-0",
	fab: "h-12 w-12 rounded-full bg-[#2563eb] p-0 text-white shadow-[var(--shadow-md)]",
} as const;
---

<Tag
	{...rest}
	href={href}
	type={href ? undefined : type}
	class:list={[
		"inline-flex cursor-pointer items-center justify-center gap-2 rounded-[var(--radius-md)] border border-transparent font-semibold transition duration-200 hover:opacity-90 active:scale-[0.98]",
		sizeClasses[size],
		variantClasses[variant],
		fullWidth && "w-full",
		customClass,
	]}
>
	<slot />
</Tag>
