---
interface Props {
	variant?: "primary" | "secondary" | "ghost" | "danger" | "gradient" | "icon" | "fab";
	size?: "sm" | "md" | "lg";
	href?: string;
	fullWidth?: boolean;
	type?: "button" | "submit" | "reset";
	class?: string;
}

const {
	variant = "primary",
	size = "md",
	href,
	fullWidth = false,
	type = "button",
	class: list = [],
	...rest
} = Astro.props;

const Tag = href ? "a" : "button";
---

<Tag
	{...rest}
	href={href}
	type={href ? undefined : type}
	class:list={[
		"btn",
		`btn--${variant}`,
		`btn--${size}`,
		fullWidth && "btn--full",
	]}
>
	<slot />
</Tag>

<style>
	.btn {
		border: 1px solid transparent;
		border-radius: var(--radius-md);
		font-weight: 600;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		justify-content: center;
		transition: 0.2s ease;
		cursor: pointer;
	}

	.btn--sm {
		padding: 0.35rem 0.65rem;
		font-size: 0.75rem;
	}

	.btn--md {
		padding: 0.55rem 0.9rem;
		font-size: 0.875rem;
	}

	.btn--lg {
		padding: 0.8rem 1.1rem;
		font-size: 0.95rem;
	}

	.btn--full {
		width: 100%;
	}

	.btn--primary {
		background: var(--color-primary);
		color: white;
	}

	.btn--gradient {
		background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
		color: white;
	}

	.btn--secondary {
		background: var(--color-bg-primary);
		border-color: var(--color-border);
		color: var(--color-text-primary);
	}

	.btn--ghost {
		background: transparent;
		color: var(--color-text-secondary);
	}

	.btn--danger {
		background: var(--color-critical);
		color: white;
	}

	.btn--icon {
		width: 2rem;
		height: 2rem;
		padding: 0;
		background: var(--color-bg-primary);
		border-color: var(--color-border);
	}

	.btn--fab {
		width: 3rem;
		height: 3rem;
		border-radius: 999px;
		background: #2563eb;
		color: white;
		box-shadow: var(--shadow-md);
		padding: 0;
	}

	.btn:hover {
		opacity: 0.92;
	}
	.btn:active {
		transform: scale(0.98);
	}
</style>
