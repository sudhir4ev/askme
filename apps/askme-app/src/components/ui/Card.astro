---
interface Props {
	variant?: "default" | "muted" | "alert" | "interactive";
	padding?: "sm" | "md" | "lg";
}

const { variant = "default", padding = "md" } = Astro.props;
const paddingClasses = {
	sm: "p-3",
	md: "p-4",
	lg: "p-6",
} as const;
const variantClasses = {
	default: "bg-[var(--color-bg-primary)]",
	muted: "bg-[var(--color-bg-secondary)]",
	alert: "border-[#fecaca] bg-[#fef2f2]",
	interactive:
		"bg-[var(--color-bg-primary)] transition duration-200 hover:-translate-y-0.5 hover:shadow-[var(--shadow-sm)]",
} as const;
---

<section
	class:list={[
		"rounded-[var(--radius-lg)] border border-[var(--color-border)]",
		paddingClasses[padding],
		variantClasses[variant],
	]}
>
	<slot />
</section>
