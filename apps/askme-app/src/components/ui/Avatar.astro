---
interface Props {
	src?: string;
	alt?: string;
	initials?: string;
	size?: "sm" | "md";
}

const { src, alt = "Avatar", initials = "ID", size = "sm" } = Astro.props;
---

<div class:list={["avatar", `avatar--${size}`]}>
	{src ? <img src={src} alt={alt} /> : <span>{initials}</span>}
</div>

<style>
	.avatar {
		border-radius: 999px;
		overflow: hidden;
		display: grid;
		place-items: center;
		background: #e5e7eb;
		color: #4b5563;
		font-weight: 700;
	}

	.avatar--sm {
		width: 2rem;
		height: 2rem;
		font-size: 0.75rem;
	}

	.avatar--md {
		width: 2.5rem;
		height: 2.5rem;
		font-size: 0.875rem;
	}

	img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
</style>
