---
interface Props {
	src?: string;
	alt?: string;
	initials?: string;
	size?: "sm" | "md";
}

const { src, alt = "Avatar", initials = "ID", size = "sm" } = Astro.props;
const sizeClasses = {
	sm: "h-8 w-8 text-xs",
	md: "h-10 w-10 text-sm",
} as const;
---

<div
	class:list={[
		"grid place-items-center overflow-hidden rounded-full bg-[#e5e7eb] font-bold text-[#4b5563]",
		sizeClasses[size],
	]}
>
	{src ? <img class="h-full w-full object-cover" src={src} alt={alt} /> : <span>{initials}</span>}
</div>
