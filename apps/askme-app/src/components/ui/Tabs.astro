---
interface TabItem {
	key: string;
	label: string;
}

interface Props {
	items: TabItem[];
	active: string;
	compact?: boolean;
}

const { items, active, compact = false } = Astro.props;
---

<nav class="flex flex-wrap gap-1.5">
	{
		items.map((item) => (
			<a
				class:list={[
					"rounded-[var(--radius-sm)] px-2.5 py-1.5 text-xs font-bold uppercase tracking-[0.04em] text-[#6b7280]",
					compact && "px-2 py-0.5",
					item.key === active && "border border-[var(--color-border)] bg-white text-[var(--color-primary)]",
				]}
				href="#"
			>
				{item.label}
			</a>
		))
	}
</nav>
