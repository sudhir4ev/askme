---
interface Props {
	value: number;
	tone?: "primary" | "critical" | "high" | "medium" | "success";
}

const { value, tone = "primary" } = Astro.props;
const clamped = Math.max(0, Math.min(100, value));
const toneClasses = {
	primary: "bg-[var(--color-primary)]",
	critical: "bg-[var(--color-critical)]",
	high: "bg-[var(--color-high)]",
	medium: "bg-[var(--color-medium)]",
	success: "bg-[var(--color-success)]",
} as const;
---

<div class="h-1.5 w-full overflow-hidden rounded-full bg-[#e5e7eb]" aria-hidden="true">
	<div class:list={["h-full rounded-full", toneClasses[tone]]} style={`width: ${clamped}%`}></div>
</div>
