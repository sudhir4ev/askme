---
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";
import SectionLabel from "../ui/SectionLabel.astro";

interface Item {
	title: string;
	body: string;
	icon: string;
}

interface Props {
	title: string;
	summary: string;
	items: Item[];
}

const { title, summary, items } = Astro.props;
---

<aside class="grid gap-3">
	<Card padding="lg">
		<h3 class="m-0">{title}</h3>
		<p class="text-[0.84rem] leading-[1.5] text-[var(--color-text-secondary)]">{summary}</p>
		<Button variant="secondary" size="sm">View Patch Plan</Button>
	</Card>

	<div class="grid gap-2">
		<SectionLabel>Key Recommendations</SectionLabel>
		{
			items.map((item) => (
				<Card padding="md">
					<div class="flex items-start gap-2.5">
						<span class="material-symbols-outlined text-[var(--color-primary)]">{item.icon}</span>
						<div>
							<strong class="block text-[0.82rem]">{item.title}</strong>
							<p class="mt-1 mb-0 text-[0.76rem] text-[var(--color-text-secondary)]">{item.body}</p>
						</div>
					</div>
				</Card>
			))
		}
	</div>
</aside>
